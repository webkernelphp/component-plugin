{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/component-modules-essentials",
    "description": "Essential core components and base classes for Webkernel modules, featuring plugins, panel providers, pages, widgets, and resources toolkit.",
    "version": "0.12.0",
    "homepage": "https://www.webkernelphp.com/",
    "type": "webkernel-component",
    "license": "EPL-2.0",
    "authors": [
        {
            "name": "El Moumen Yassine",
            "email": "yassine@numerimondes.com",
            "homepage": "https://webkernelphp.com/about"
        }
    ],
    "support": {
        "issues": "https://github.com/webkernelphp/component-modules-essentials/issues"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "*",
        "filament/filament": "*",
        "webkernel/standard-lifecycle": "0.12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Webkernel\\Component\\ModEssentials\\": "src/"
        },
        "classmap": [
            "classmap/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Webkernel\\Component\\ModEssentials\\Tests\\": "tests/",
            "Workbench\\ModEssentials\\App\\": "workbench/app/"
        }
    },
    "extra": {
        "laravel": {
            "providers": []
        },
        "webkernel": {
            "package_repo": "git@github.com:webkernelphp/component-modules-essentials.git",
            "prefix": "component-modules-essentials",
            "config_scope": "modules-essentials"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
